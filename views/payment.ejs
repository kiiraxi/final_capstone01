<!DOCTYPE html>
<html>
<head>
  <title>Online Payment</title>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
  />
</head>
<body class="p-4 bg-light">
  <div
    class="container d-flex justify-content-center align-items-center"
    style="min-height: 100vh;"
  >
    <div class="card shadow-lg p-4 text-center" style="max-width: 400px; width: 100%;">
      <h2 class="mb-4 fw-bold">Online Payment</h2>

      <p>Reference Number: <strong><%= ref %></strong></p>
      <p>Amount to Pay: <strong>₱<%= amount %></strong></p>

      <hr />

      <!-- <p class="mb-3">Choose a payment method:</p> -->

      <div class="d-flex flex-column gap-2">
      <button class="btn btn-primary" onclick="payViaGCash()">Pay</button>
       
      </div>
    </div>
  </div>
<script>
  async function payViaGCash() {
    const response = await fetch('http://localhost:5000/create-payment', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        amount: <%- JSON.stringify(amount) %>,
        email: 'applicant@email.com',
        name: 'Applicant Name',
        ref: <%- JSON.stringify(ref) %>
      })
    });

    const data = await response.json();
    if (data.link) {
      window.location.href = data.link;
    } else {
      alert('Failed to create payment.');
      console.log("Server response:", data);
    }
  }
</script>

</body>
</html>
