<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Tax Report</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
   

    <style>
      .dropdown-item:hover {
           background-color: #0d6efd;
           color: white;
        }
</style>

</head>
<body >

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container-fluid">
    <div class="d-flex align-items-center">
      <img src="assets/img/leonlogo.png" alt="Treasury Office Logo" style="max-width: 100px; margin-right: 20px;">
      <a class="navbar-brand mb-0 h1" href="#">Cedula Admin Office</a>
    </div>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarResponsive">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarResponsive">
      <ul class="navbar-nav ms-auto align-items-center">
        <li class="nav-item dropdown me-3">
          <a class="nav-link dropdown-toggle" href="#" id="navDropdownIcon" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <span class="navbar-toggler-icon"></span>
          </a>
          <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navDropdownIcon">
            <li><a class="dropdown-item" href="/admin">Dashboard</a></li>
            <li><a class="dropdown-item" href="/taxreport">Tax Report</a></li>
            <li><a class="dropdown-item" href="/adminlogin.html">Logout</a></li>
          </ul>
        </li>
      </ul>
    </div>
  </div>
</nav>



    <div class="container mt-5">
        <h1 class="text-center mb-4">Tax Collection</h1>

        <table class="table table-bordered text-center">
            <thead class="table-dark">
                <tr>
                    <th>Month</th>
                    <th>Total Tax Collected (₱)</th>
                </tr>
            </thead>
            <tbody>
                <% let grandTotal = 0; %>
                <% taxData.forEach(item => { %>
                    <tr>
                        <td><%= item.month %></td>
                        <td>₱<%= item.total.toLocaleString() %></td>
                        <% grandTotal += item.total; %>
                    </tr>
                <% }); %>
            </tbody>
            <tfoot class="table-secondary">
                <tr>
                    <th>Total for the Year</th>
                    <th>₱<%= grandTotal.toLocaleString() %></th>
                </tr>
            </tfoot>
        </table>
    </div>
   <div style="position: fixed; bottom: 20px; right: 20px; z-index: 999;">
    <button onclick="generatePDF()" class="btn btn-primary">Download PDF</button>
</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<script>
  async function generatePDF() {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF();

    
    doc.setFontSize(18);
    doc.text("Tax Report", 14, 22);

  
    const today = new Date().toLocaleString();
    doc.setFontSize(10);
    doc.text(`Generated: ${today}`, 14, 30);

    
    doc.autoTable({
      html: '.table',
      startY: 40,
      theme: 'grid',
    });

    
    doc.save("tax-report.pdf");
  }
</script>



    <!-- Bootstrap JS Bundle with Popper (required for dropdowns) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<!-- jsPDF core -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<!-- jsPDF AutoTable -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>


</body>
</html>
