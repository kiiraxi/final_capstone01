        <!-- Issued Cedula Section -->
<div class="card mt-4">
   <div class="card-header" style="background-color: #5298ee; color: white; text-align: center; font-size: 20px;">
                    Issued Cedula
                </div>
  </div>
  <div class="card-body">
    <table class="table table-bordered table-striped text-center">
      <thead class="table-primary">
        <tr>
          <th>No.</th>
          <th>User ID</th>
          <th>Full Name</th>
          <th>Certificate Type</th>
          <th>Date Released</th>
          <th>Status</th>
          <th>Payment Status</th>
          
        </tr>
      </thead>
      <tbody>
  <% if (issuedData && issuedData.length > 0) { %>
    <% issuedData.forEach((data, index) => { %>
      <tr>
        <td><%= index + 1 %></td>
        <td><%= data.USER_ID %></td>
        <td><%= data.FIRST_NAME %> <%= data.LAST_NAME %></td>
        <td><%= data.CERTIFICATE_TYPE %></td>
        <td><%= data.DATE_ISSUED %></td>
       <td>
  <% if (data.STATUS === 'Issued' || data.STATUS === 'Done') { %>
    <span class="badge bg-primary">Done</span>
  <% } else { %>
    <span class="badge bg-secondary"><%= data.STATUS %></span>
  <% } %>
</td>

        <td>
          <% if (data.PAYMENT_STATUS === 'Paid') { %>
            <span class="badge bg-success">Paid</span>
          <% } else if (data.PAYMENT_STATUS === 'Pending') { %>
            <span class="badge bg-warning text-dark">Pending</span>
          <% } else { %>
            <span class="badge bg-danger">Unpaid</span>
          <% } %>
        </td>
      </tr>
    <% }); %>
  <% } else { %>
    <tr>
      <td colspan="7" class="text-center">No issued cedula found.</td>
    </tr>
  <% } %>
</tbody>

    </table>
  </div>
</div>


    </div>
    
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".modal").forEach(modal => {
                modal.addEventListener("shown.bs.modal", function () {
                    const grossReceipt = modal.querySelector("[name='gross_receipt']");
                    const annualIncome = modal.querySelector("[name='annual_income']");
                    const realPropertyIncome = modal.querySelector("[name='real_property_income']");
                    const totalTaxable = modal.querySelector("#total_taxable");
                    const ctcAmount = modal.querySelector("#ctc_amount");
        
                    function calculateTax() {
                        let gr = parseFloat(grossReceipt?.value) || 0;
                        let ai = parseFloat(annualIncome?.value) || 0;
                        let rp = parseFloat(realPropertyIncome?.value) || 0;
        
                        let total = gr + ai + rp;
                        let tax = 5 + (total * 0.01); 
        
                        if (totalTaxable) {
                            totalTaxable.value = total.toLocaleString('en-PH', { minimumFractionDigits: 2 });
                        }
                        if (ctcAmount) {
                            ctcAmount.value = tax.toLocaleString('en-PH', { minimumFractionDigits: 2 });
                        }
                    }
        
                    [grossReceipt, annualIncome, realPropertyIncome].forEach(input => {
                        input?.addEventListener("input", calculateTax);
                    });
        
                    calculateTax(); 
                });
            });
        });
        </script>
        


    
    <script>
        function deleteRecord(id, firstName, lastName) {
            if (confirm(`Are you sure you want to delete ${firstName} ${lastName}?`)) {
                fetch(`/delete/${id}`, { method: 'DELETE' })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Record deleted successfully!');
                        location.reload(); // Refresh page after deletion
                    } else {
                        alert(data.message);
                    }
                })
                .catch(error => console.error('Error:', error));
            }
        }
        </script>
        
        


    <script>
        // Fetch data for statistics
        function fetchStats() {
            fetch('/admin/stats')
                .then(response => response.json())
                .then(data => {
                    // Update the HTML with the fetched data
                    document.getElementById('totalUsers').textContent = data.totalUsers || '0';
                    document.getElementById('pendingReservations').textContent = data.pendingReservations || '0';
                    document.getElementById('approvedCedula').textContent = data.approvedCedula || '0';
                    document.getElementById('rejectedCedula').textContent = data.rejectedCedula || '0';
                })
                .catch(err => {
                    console.error('Error fetching stats:', err);
                    document.getElementById('totalUsers').textContent = 'Error loading data';
                    document.getElementById('pendingReservations').textContent = 'Error loading data';
                    document.getElementById('approvedCedula').textContent = 'Error loading data';
                    document.getElementById('rejectedCedula').textContent = 'Error loading data';
                });
        }

       
        window.onload = fetchStats;
    </script>
    
</body>
</html>
